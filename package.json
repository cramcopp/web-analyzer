{
  "name": "ai-studio-applet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "deploy:workflow": "wrangler deploy -c workflow-wrangler.toml",
    "deploy:all": "npm run deploy:workflow && npm run deploy",
    "cf:build": "opennextjs-cloudflare build",
    "cf:dry-run": "npm run cf:build && wrangler deploy --dry-run -c wrangler.toml && wrangler deploy --dry-run -c workflow-wrangler.toml",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint .",
    "clean": "next clean",
    "scan": "eslint . && knip"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.5",
    "autoprefixer": "^10.4.21",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.553.0",
    "motion": "^12.38.0",
    "next": "15.5.15",
    "node-html-parser": "^7.1.0",
    "postcss": "^8.5.13",
    "postcss-load-config": "^6.0.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260502.1",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "4.1.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.1",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "knip": "^6.7.0",
    "tailwindcss": "4.1.11",
    "typescript": "5.9.3",
    "wrangler": "^4.87.0"
  },
  "knip": {
    "entry": [
      "app/**/page.tsx",
      "app/**/layout.tsx",
      "app/api/**/route.ts",
      "lib/workflow-scanner.ts",
      "open-next.config.ts"
    ],
    "project": [
      "**/*.{ts,tsx,js,jsx}"
    ],
    "ignoreDependencies": [
      "cloudflare",
      "tailwindcss"
    ],
    "rules": {
      "exports": "off",
      "types": "off"
    }
  },
  "overrides": {
    "next": {
      "postcss": "8.5.13"
    }
  }
}
