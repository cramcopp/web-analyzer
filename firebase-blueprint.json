{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Auth UID" },
        "email": { "type": "string", "description": "User email address" },
        "displayName": { "type": "string", "description": "Display name of the user" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "Role of the user" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Report": {
      "title": "Report",
      "description": "A saved website analysis report generated by the user",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user who ran the report" },
        "url": { "type": "string", "description": "The analyzed URL" },
        "score": { "type": "number", "description": "Overall score" },
        "results": { "type": "string", "description": "JSON string of the report results" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "url", "results", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A user project that saves a website that needs a recurring crawl.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the project" },
        "name": { "type": "string", "description": "User defined project name" },
        "url": { "type": "string", "description": "Target URL to crawl" },
        "cronEnabled": { "type": "boolean", "description": "Whether to analyze automatically every 24h" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "url", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/reports/{reportId}": {
      "schema": { "$ref": "#/entities/Report" },
      "description": "Stores website analysis reports."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "User projects for regular crawling."
    }
  }
}
